# Formspree form endpoint for the counselling enroll modal.
# Create a form at https://formspree.io with email info@collegecare.in and paste the form URL here.
# Example: https://formspree.io/f/xxxxxxxx
VITE_FORMSPREE_COUNSELLING_URL=

# Optional: Pexels API key for gallery auto-update (fetches fresh photos by category). Get a free key at https://www.pexels.com/api
# If not set, the gallery uses the curated static image list.
VITE_PEXELS_API_KEY=
